# Groq API Key (required — get yours at https://console.groq.com)
GROQ_API_KEY=gsk_your-groq-api-key-here

# MongoDB Connection
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=rag_system

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_data

# Server
HOST=0.0.0.0
PORT=8000

# LLM Model (Groq-hosted models: llama-3.1-8b-instant, mixtral-8x7b-32768, etc.)
LLM_MODEL=llama-3.1-8b-instant

# Chunk Settings
CHUNK_SIZE=500
CHUNK_OVERLAP=50
